# Copy this file to .env or set these variables in your shell.
# Do not commit real API keys.

# Used by src/extract_phrases_langchain.py when --provider qwen
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# Embedding settings. If omitted, src/extract_phrases_langchain.py will try
# EMBEDDING_API_KEY, then OPENAI_API_KEY, then DASHSCOPE_API_KEY.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# Optional alternatives
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
